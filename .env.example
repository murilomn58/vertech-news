# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Auth.js (NextAuth v5)
AUTH_SECRET=              # Run: npx auth secret
AUTH_GOOGLE_ID=           # Google Cloud Console OAuth client ID
AUTH_GOOGLE_SECRET=       # Google Cloud Console OAuth client secret

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=   # G-XXXXXXXXXX

# Google Search Console (optional)
NEXT_PUBLIC_GSC_VERIFICATION=    # HTML meta tag content value

# ISR Revalidation
REVALIDATION_SECRET=
NEXT_PUBLIC_SITE_URL=https://vertechnews.vercel.app

# IP hashing salt for analytics
IP_HASH_SALT=

# ---------- Monetization (Phase 1+) ----------

# Newsletter (required for email delivery — without RESEND_API_KEY, signups are stored but no emails are sent)
# Setup: 1) Create free account at https://resend.com  2) Get API key from dashboard
# Testing: Use NEWSLETTER_FROM="Vertech News <onboarding@resend.dev>" (Resend's pre-verified sender)
# Production: Verify your domain in Resend, then use NEWSLETTER_FROM="Vertech News <news@vertechnews.com>"
NEWSLETTER_SECRET=         # Auth secret for /api/newsletter/send (also set in GitHub repo secrets)
NEWSLETTER_FROM=           # e.g. "Vertech News <onboarding@resend.dev>" for testing
RESEND_API_KEY=            # Resend.com API key (free: 3K emails/mo) — REQUIRED for welcome + weekly emails

# Push Notifications (optional - Phase 4)
VAPID_PUBLIC_KEY=          # Generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_EMAIL=               # Contact email for VAPID
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # Same as VAPID_PUBLIC_KEY (client-side)
PUSH_SECRET=               # Auth secret for /api/push/send

# Display Ads (optional - Phase 3)
NEXT_PUBLIC_ADSENSE_CLIENT=    # Google AdSense client ID
NEXT_PUBLIC_CARBON_SERVE=      # Carbon Ads serve ID

# ---------- AI Features (deferred — not needed for initial deploy) ----------
# Without this key, the site works 100%. Article pages show RSS descriptions
# instead of AI summaries, and PT-BR pages show English text instead of
# translations. Add this later to unlock AI summaries + PT-BR translation.
# Cost: ~$8/month for ~100 articles/week.
# ANTHROPIC_API_KEY=
